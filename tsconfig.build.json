{
  "extends": "./tsconfig.app.json",
  "include": ["env.d.ts", "src/**/*.ts", "src/**/*.vue"],
  "exclude": [
    "src/dev/**",
    "src/stories/**",
    "src/**/__tests__/**",
    "src/**/*.spec.ts",
    "src/**/*.stories.ts"
  ],
  "compilerOptions": {
    "composite": false,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.build.tsbuildinfo"
  }
}
