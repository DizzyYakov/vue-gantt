{
  "name": "@dizzy_yakov/vue-gantt",
  "version": "1.0.0",
  "type": "module",
  "description": "Headless, composable Gantt chart components for Vue 3",
  "license": "MIT",
  "keywords": [
    "vue",
    "vue3",
    "gantt",
    "gantt-chart",
    "timeline",
    "scheduler",
    "headless"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LavaYasha/vue-gantt.git"
  },
  "homepage": "https://github.com/LavaYasha/vue-gantt#readme",
  "bugs": {
    "url": "https://github.com/LavaYasha/vue-gantt/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/vue-gantt.js",
  "module": "./dist/vue-gantt.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-gantt.js"
    },
    "./styles": "./dist/gantt.css",
    "./styles.css": "./dist/gantt.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "run-s type-check build-only build:types",
    "prepack": "bun run build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "bench": "vitest bench --run",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:browser": "vitest run -c vitest.browser.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e:install": "playwright install",
    "test:stories": "run-s build-storybook test:stories:run",
    "test:stories:run": "playwright test -c playwright.stories.config.ts",
    "test:visual": "run-s build-storybook test:visual:run",
    "test:visual:run": "playwright test -c playwright.visual.config.ts"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "date-fns": "^4.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-docs": "^10",
    "@storybook/vue3-vite": "^10",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-vue": "~10.8.0",
    "http-server": "^14.1.1",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.60.0",
    "prettier": "^3.4.2",
    "sass-embedded": "^1.100.0",
    "storybook": "^10",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "4.1.10",
    "vitest-browser-vue": "^2.1.0",
    "vue": "^3.5.13",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
